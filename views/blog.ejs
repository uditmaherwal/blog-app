<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
    <title>Blogs</title>
</head>

<body>
  <%- include('./partials/scripts') %> <%- include('./partials/nav') %>
      <div class="container mt-4 align-items-center">
        <h1>
          <%= blog.title %>
        </h1>
        <img src="<%= blog.coverImageUrl %>" width="500px" />
        <pre class="mt-3"><%= blog.content %></pre>
      </div>
      <div class="container mt-4 align-items-center">
        <img src="/images/default.png" width="100px" class="rounded-circle" />
        <span>
          <%= blog.createdBy.fullName %>
        </span>
      </div>
      <div class="container mt-4 mb-4 align-items-center">
        <h2>Comments <span class="badge bg-secondary"><%= comments.length %></span></h2>
        <% if (locals.user) { %>
        <form action="/blog/comment/<%= blog._id %>" method="POST">
          <div class="mb-3">
            <input type="text" class="form-control" id="email" name="content" placeholder="Enter your comment" />
          </div>
          <button type="submit" class="btn btn-primary">Submit</button>
        </form>

        <% } %>
                <div>
          <% comments.forEach(comment => { %>
          <div class="card mt-3">
            <div class="card-body">
              <div class="d-flex align-items-center mb-2">
                <img src="/images/default.png" width="25px" class="rounded-circle" />
                <span class="ms-2">
                  <%= comment.createdBy.fullName %>
                </span>
              </div>
              <p><%= comment.content %></p>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
</body>

</html>