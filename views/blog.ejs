<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blogs</title>
  </head>
  <body>
    <%- include('./partials/scripts') %> <%- include('./partials/nav') %>
    <div class="container mt-4 align-items-center">
      <h1><%= blog.title %></h1>
      <img src="<%= blog.coverImageUrl %>" width="500px" />
      <pre class="mt-3"><%= blog.content %></pre>
    </div>
    <div class="container mt-4 align-items-center">
      <img
        src="<%= blog.createdBy.profileImageUrl %>"
        width="100px"
        class="rounded-circle"
      />
      <span><%= blog.createdBy.fullName %></span>
    </div>
  </body>
</html>
