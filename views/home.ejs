<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blog Application</title>
  </head>

  <body>
    <%- include('./partials/scripts') %> <%- include('./partials/nav') %>
    <div class="container mt-4 d-flex gap-4 flex-wrap align-items-stretch">
      <% blogs.forEach((blog) => { %>
        <div class="card" style="width: 18rem;">
          <img src="<%= blog.coverImageUrl %>" class="card-img-top align-self-stretch" alt="Blog Cover Image" style="height: 200px; object-fit: cover;">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title align-self-start"><%= blog.title %></h5>
            <a href="/blog/<%= blog._id %>" class="btn btn-primary mt-auto">View</a>
          </div>
        </div>
      <% }) %>
    </div>
  </body>
</html>
